@page "/"

<PageTitle>Blazor ApexGrid</PageTitle>

<h1>Blazor ApexGrid</h1>
<p>A typed <code>ApexGrid&lt;TItem&gt;</code> with sorting, filtering, pagination, selection, inline editing, undo/redo, column operations, and state persistence.</p>

<div style="display:flex; gap:8px; flex-wrap:wrap; margin:0.5rem 0 1rem; align-items:center;">
    <input placeholder="Quick filter..." @oninput="OnFilter" style="padding:6px 10px; width:220px;" />
    <button @onclick="SortByNameAsc">Sort name ▲</button>
    <button @onclick="() => _grid!.ClearSortAsync()">Clear sort</button>
    <button @onclick="() => _grid!.SelectAllRowsAsync()">Select all</button>
    <button @onclick="() => _grid!.ClearSelectionAsync()">Clear selection</button>
    <button @onclick="() => _grid!.NextPageAsync()">Next page</button>
    <button @onclick="() => _grid!.PreviousPageAsync()">Prev page</button>
    <span>Selected: <strong id="sel-count">@_selectedCount</strong></span>
</div>

<div style="display:flex; gap:8px; flex-wrap:wrap; margin:0 0 1rem; align-items:center;">
    <button id="pin-name" @onclick="PinName">Pin Name column</button>
    <button @onclick="UnpinName">Unpin Name</button>
    <button @onclick="() => _grid!.UndoAsync()" disabled="@(!_canUndo)">Undo</button>
    <button @onclick="() => _grid!.RedoAsync()" disabled="@(!_canRedo)">Redo</button>
    <button id="save-state" @onclick="SaveState">Save state</button>
    <button @onclick="RestoreState" disabled="@(_savedState is null)">Restore state</button>
    <span>State: <strong id="state-len">@(_savedState?.GetRawText().Length ?? 0)</strong> chars</span>
</div>

<p style="font-size:13px; color:#57606a; margin:0 0 0.5rem;">Double-click an Age or Role cell to edit inline. Edits are tracked for undo/redo.</p>

<ApexGrid TItem="Person" @ref="_grid"
          Data="_people"
          Columns="_columns"
          Height="360px"
          SortConfiguration="_sort"
          Pagination="_pagination"
          Selection="_selection"
          Editing="_editing"
          ColumnReordering="true"
          OnSorted="OnSorted"
          OnRowSelected="OnRowSelected"
          OnPageChanged="OnPageChanged"
          OnColumnPinned="OnColumnPinned"
          OnCellValueChanged="OnCellValueChanged"
          OnHistoryChanged="OnHistoryChanged" />

<pre id="event-log" style="margin-top:1rem; background:#f6f8fa; padding:10px; border-radius:6px; max-height:160px; overflow:auto; font-size:12px;">@_log</pre>

@code {
    private ApexGrid<Person>? _grid;
    private int _selectedCount;
    private bool _canUndo;
    private bool _canRedo;
    private JsonElement? _savedState;
    private string _log = "";

    private readonly GridSortConfiguration _sort = new() { Multiple = true, TriState = true };
    private readonly PaginationConfiguration _pagination = new() { Enabled = true, PageSize = 5, PageSizeOptions = new() { 5, 10, 25 } };
    private readonly GridSelectionConfiguration _selection = new() { Enabled = true, Mode = SelectionMode.Multiple, ShowCheckboxColumn = true };
    private readonly GridEditingConfiguration _editing = new()
    {
        Enabled = true,
        Mode = EditMode.Cell,
        Trigger = EditTrigger.DoubleClick,
        History = new() { Enabled = true },
    };

    private readonly List<GridColumn<Person>> _columns = new()
    {
        new() { Key = "name", HeaderText = "Name", Sort = true, Filter = true },
        new() { Key = "age", HeaderText = "Age", Type = GridDataType.Number, Sort = true, Editable = true },
        new() { Key = "role", HeaderText = "Role", Filter = true, Sort = true, Editable = true },
        new() { Key = "active", HeaderText = "Active", Type = GridDataType.Boolean },
    };

    private readonly List<Person> _people = new()
    {
        new() { Name = "Ada Lovelace", Age = 36, Role = "Mathematician", Active = true },
        new() { Name = "Alan Turing", Age = 41, Role = "Computer Scientist", Active = true },
        new() { Name = "Grace Hopper", Age = 44, Role = "Rear Admiral", Active = false },
        new() { Name = "Katherine Johnson", Age = 52, Role = "Physicist", Active = true },
        new() { Name = "Edsger Dijkstra", Age = 48, Role = "Programmer", Active = false },
        new() { Name = "Barbara Liskov", Age = 45, Role = "Computer Scientist", Active = true },
        new() { Name = "Donald Knuth", Age = 55, Role = "Author", Active = true },
        new() { Name = "Margaret Hamilton", Age = 42, Role = "Engineer", Active = true },
        new() { Name = "Linus Torvalds", Age = 39, Role = "Programmer", Active = false },
        new() { Name = "Tim Berners-Lee", Age = 50, Role = "Inventor", Active = true },
    };

    private async Task OnFilter(ChangeEventArgs e)
    {
        if (_grid is not null) await _grid.SetQuickFilterAsync(e.Value?.ToString() ?? "");
    }

    private async Task SortByNameAsc()
    {
        if (_grid is not null)
            await _grid.SortAsync(new GridSortExpression { Key = "name", Direction = SortingDirection.Ascending });
    }

    private async Task PinName()
    {
        if (_grid is not null) await _grid.PinColumnAsync("name", PinPosition.Start);
    }

    private async Task UnpinName()
    {
        if (_grid is not null) await _grid.UnpinColumnAsync("name");
    }

    private async Task SaveState()
    {
        if (_grid is not null)
        {
            _savedState = await _grid.GetStateAsync();
            Log($"saved state ({_savedState?.GetRawText().Length ?? 0} chars)");
        }
    }

    private async Task RestoreState()
    {
        if (_grid is not null && _savedState is not null)
        {
            await _grid.SetStateAsync(_savedState.Value);
            Log("restored state");
        }
    }

    private void OnSorted(GridSortEventArgs e) => Log($"sorted: {e.Key} {e.Direction}");
    private void OnPageChanged(GridPageChangedEventArgs e) => Log($"pageChanged: page {e.Page + 1}/{e.PageCount} (size {e.PageSize})");
    private void OnColumnPinned(GridColumnPinnedEventArgs e) => Log($"columnPinned: {e.Key} -> {e.Pinned ?? "unpinned"}");
    private void OnCellValueChanged(GridCellValueChangedEventArgs<Person> e) => Log($"cellValueChanged: {e.Key} row {e.RowIndex} = {e.Value}");

    private void OnHistoryChanged(GridHistoryChangedEventArgs e)
    {
        _canUndo = e.CanUndo;
        _canRedo = e.CanRedo;
        Log($"historyChanged: canUndo={e.CanUndo} canRedo={e.CanRedo}");
    }

    private void OnRowSelected(GridRowSelectedEventArgs<Person> e)
    {
        _selectedCount = e.Selected.Count;
        Log($"rowSelected: {e.Selected.Count} selected (+{e.Added.Count}/-{e.Removed.Count})");
    }

    private void Log(string message)
    {
        _log = $"{message}\n{_log}";
        StateHasChanged();
    }

    public class Person
    {
        public string Name { get; set; } = "";
        public int Age { get; set; }
        public string Role { get; set; } = "";
        public bool Active { get; set; }
    }
}
